DATABASE_URL=postgresql://xray:xray-password@postgres:5432/xray_scope
POSTGRES_DB=xray_scope
POSTGRES_USER=xray
POSTGRES_PASSWORD=xray-password

PANEL_USERNAME=admin
PANEL_PASSWORD=replace-with-a-long-password
COLLECTOR_TOKEN=replace-with-a-random-token
EVENT_RETENTION_HOURS=72
LOG_LEVEL=info

# Optional AI analysis. Keep the key server-side and never commit a real value.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://books.synapse-web.ru/
OPENROUTER_APP_NAME=Xray Scope

XRAY_ACCESS_LOG_PATH=/var/log/xray/access.log
XRAY_LOG_DIR=/path/to/xray/logs
NODE_ID=finland-1
WEB_API_URL=http://web:3000
COLLECTOR_BATCH_SIZE=100
COLLECTOR_FLUSH_INTERVAL_MS=1000
COLLECTOR_STATE_PATH=/data/collector-state.json
COLLECTOR_MAX_QUEUE_SIZE=10000
XRAY_METRICS_URL=http://127.0.0.1:11111/debug/vars
XRAY_METRICS_INTERVAL_MS=15000
